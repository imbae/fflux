<ui:FluentWindow
    x:Class="fflux.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:fflux.UI"
    xmlns:player="clr-namespace:fflux.UI.Modules.Player"
    xmlns:explorer="clr-namespace:fflux.UI.Modules.FFmpegExplorer"
    xmlns:analyzer="clr-namespace:fflux.UI.Modules.VideoAnalyzer"
    xmlns:batch="clr-namespace:fflux.UI.Modules.BatchQueue"
    xmlns:scene="clr-namespace:fflux.UI.Modules.SceneDetector"
    xmlns:bitrate="clr-namespace:fflux.UI.Modules.BitrateAnalyzer"
    xmlns:settings="clr-namespace:fflux.UI.Modules.Settings"
    xmlns:aisubtitle="clr-namespace:fflux.UI.Modules.AiSubtitle"
    mc:Ignorable="d"
    Title="fflux"
    Width="1280"
    Height="900"
    MinWidth="960"
    MinHeight="600"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <!-- TitleBar -->
            <RowDefinition
                Height="Auto" />
            <!-- NavigationView + Content -->
            <RowDefinition
                Height="*" />
            <!-- StatusBar -->
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ══ TitleBar ════════════════════════════════════════════ -->
        <ui:TitleBar
            Grid.Row="0"
            Title="fflux" />

        <!-- ══ NavigationView ══════════════════════════════════════ -->
        <ui:NavigationView
            Grid.Row="1"
            x:Name="RootNavigation"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleVisible="True"
            OpenPaneLength="220">

            <ui:NavigationView.MenuItems>

                <!-- 🎬 Player -->
                <ui:NavigationViewItem
                    Content="Player"
                    TargetPageType="{x:Type player:PlayerPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon
                            Symbol="Play24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <!-- 🛠️ FFmpeg Explorer -->
                <ui:NavigationViewItem
                    Content="FFmpeg Explorer"
                    TargetPageType="{x:Type explorer:FFmpegExplorerPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon
                            Symbol="Wrench24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <!-- 📊 Video Analyzer -->
                <ui:NavigationViewItem
                    Content="Video Analyzer"
                    TargetPageType="{x:Type analyzer:VideoAnalyzerPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon
                            Symbol="DataTrending24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <!-- 📋 Batch Queue -->
                <ui:NavigationViewItem
                    Content="Batch Queue"
                    TargetPageType="{x:Type batch:BatchQueuePage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon
                            Symbol="StackStar24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <!-- 🎬 Scene Detector -->
                <ui:NavigationViewItem
                    Content="Scene Detector"
                    TargetPageType="{x:Type scene:SceneDetectorPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon
                            Symbol="Filmstrip24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <!-- 📈 Bitrate Analyzer -->
                <ui:NavigationViewItem
                    Content="Bitrate Analyzer"
                    TargetPageType="{x:Type bitrate:BitrateAnalyzerPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon
                            Symbol="DataTrending24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <!-- 🎙 AI Subtitle -->
                <ui:NavigationViewItem
                    Content="AI Subtitle"
                    TargetPageType="{x:Type aisubtitle:AiSubtitlePage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon
                            Symbol="Translate24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>

                <!-- ⚙️ Settings -->
                <ui:NavigationViewItem
                    Content="Settings"
                    TargetPageType="{x:Type settings:SettingsPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon
                            Symbol="Settings24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

            </ui:NavigationView.FooterMenuItems>

        </ui:NavigationView>

        <!-- ══ Snackbar Presenter (컨텐츠 영역 하단) ════════════════ -->
        <ui:SnackbarPresenter
            Grid.Row="1"
            x:Name="RootSnackbarPresenter"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Stretch"
            Margin="16,0,16,16"
            Panel.ZIndex="10" />

        <!-- ══ StatusBar ═══════════════════════════════════════════ -->
        <Border
            Grid.Row="2"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource FFluxBorderBrush}">

            <Grid
                Height="26"
                Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 파일명 -->
                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <ui:SymbolIcon
                        Symbol="Document24"
                        FontSize="13"
                        Margin="0,0,6,0"
                        Foreground="{DynamicResource TextFillColorDisabledBrush}" />
                    <TextBlock
                        Text="{Binding CurrentFileName}"
                        FontSize="12"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- 구분선 -->
                <Rectangle
                    Grid.Column="1"
                    Width="1"
                    Height="14"
                    Margin="12,0"
                    Fill="{DynamicResource FFluxBorderBrush}" />

                <!-- 재생 상태 -->
                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <ui:SymbolIcon
                        Symbol="Stop24"
                        FontSize="13"
                        Margin="0,0,5,0"
                        Foreground="{DynamicResource TextFillColorDisabledBrush}" />
                    <TextBlock
                        Text="{Binding PlaybackStatusText}"
                        FontSize="12"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- 우측 여백 -->
                <Rectangle
                    Grid.Column="3"
                    Width="4" />

            </Grid>
        </Border>

        <!-- ══ ContentDialog Host (최상위 오버레이) ════════════════ -->
        <ui:ContentDialogHost
            Grid.Row="0"
            Grid.RowSpan="3"
            x:Name="RootContentDialogHost"
            Panel.ZIndex="100" />

    </Grid>
</ui:FluentWindow>
