<Page
    x:Class="fflux.UI.Modules.AiSubtitle.AiSubtitlePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:conv="clr-namespace:fflux.UI.Shared.Converters"
    xmlns:local="clr-namespace:fflux.UI.Modules.AiSubtitle"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=local:AiSubtitleViewModel, IsDesignTimeCreatable=False}"
    d:DesignHeight="680"
    d:DesignWidth="800"
    Title="AI Subtitle">

    <Page.Resources>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <BooleanToVisibilityConverter         x:Key="BoolToVis" />
        <conv:StringToVisibilityConverter     x:Key="StrToVis" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16" MaxWidth="720">

            <!-- 페이지 헤더 -->
            <TextBlock
                Text="AI 자막 생성"
                FontSize="22"
                FontWeight="SemiBold"
                Margin="0,0,0,4"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <TextBlock
                Text="동영상 파일에서 Whisper로 음성을 전사하고 Groq / DeepL로 번역한 .srt 파일을 생성합니다."
                FontSize="13"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap"
                Margin="0,0,0,20" />

            <!-- ── 소스 동영상 ── -->
            <ui:CardExpander
                Header="📁 소스 동영상 파일"
                IsExpanded="True"
                Margin="0,0,0,12">
                <StackPanel Margin="0,8,0,0">

                    <TextBlock
                        Text="동영상 파일"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox
                            Grid.Column="0"
                            Text="{Binding MediaFilePath, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="파일 경로를 입력하거나 찾아보기를 클릭하세요"
                            IsReadOnly="True" />
                        <ui:Button
                            Grid.Column="2"
                            Content="찾아보기"
                            Command="{Binding BrowseMediaFileCommand}"
                            Appearance="Secondary" />
                    </Grid>

                    <TextBlock
                        Text="출력 .srt 경로 (비우면 동영상 파일과 같은 폴더에 자동 저장)"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Margin="0,12,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox
                            Grid.Column="0"
                            Text="{Binding OutputSrtPath, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="(자동)" />
                        <ui:Button
                            Grid.Column="2"
                            Content="찾아보기"
                            Command="{Binding BrowseOutputPathCommand}"
                            Appearance="Secondary" />
                    </Grid>

                </StackPanel>
            </ui:CardExpander>

            <!-- ── 번역 설정 ── -->
            <ui:CardExpander
                Header="🌐 번역 설정"
                IsExpanded="True"
                Margin="0,0,0,12">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 대상 언어 -->
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Text="대상 언어"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Margin="0,0,0,4" />
                        <ComboBox
                            ItemsSource="{x:Static local:AiSubtitleViewModel.SupportedLanguages}"
                            SelectedValuePath="Code"
                            SelectedValue="{Binding TargetLanguage}"
                            DisplayMemberPath="DisplayName" />
                    </StackPanel>

                    <!-- 번역 엔진 -->
                    <StackPanel Grid.Column="2">
                        <TextBlock
                            Text="번역 엔진"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Margin="0,0,0,4" />
                        <ComboBox
                            ItemsSource="{x:Static local:AiSubtitleViewModel.EngineNames}"
                            SelectedIndex="{Binding EngineIndex}" />
                    </StackPanel>
                </Grid>
            </ui:CardExpander>

            <!-- ── 실행 버튼 ── -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:Button
                    Grid.Column="0"
                    Content="🎬 자막 생성 시작"
                    FontSize="14"
                    Appearance="Primary"
                    HorizontalAlignment="Stretch"
                    Command="{Binding GenerateCommand}" />

                <ui:Button
                    Grid.Column="2"
                    Content="취소"
                    Appearance="Caution"
                    Command="{Binding CancelCommand}"
                    Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}" />
            </Grid>

            <!-- ── 진행률 ── -->
            <StackPanel
                Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}"
                Margin="0,0,0,12">
                <TextBlock
                    Text="{Binding StageText}"
                    FontSize="13"
                    Margin="0,0,0,6"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ProgressBar
                    Value="{Binding OverallProgress}"
                    Minimum="0"
                    Maximum="1"
                    Height="8" />
            </StackPanel>

            <!-- ── 결과 메시지 ── -->
            <TextBlock
                Text="{Binding ResultMessage}"
                FontSize="13"
                Foreground="{Binding ResultColor}"
                Visibility="{Binding ResultMessage, Converter={StaticResource StrToVis}}"
                TextWrapping="Wrap"
                Margin="0,0,0,12" />

        </StackPanel>
    </ScrollViewer>

</Page>
