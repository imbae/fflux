<UserControl
    x:Class="fflux.UI.Modules.MisbViewer.MisbMetadataPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:fflux.UI.Modules.MisbViewer"
    IsHitTestVisible="True"
    Width="250">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- 섹션 헤더 -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="10" />
            <Setter Property="FontWeight"   Value="SemiBold" />
            <Setter Property="Foreground"   Value="#FF7C5CBF" />
            <Setter Property="Margin"       Value="10,8,10,4" />
        </Style>

        <!-- 구분선 -->
        <Style x:Key="Divider" TargetType="Border">
            <Setter Property="Height"       Value="1" />
            <Setter Property="Background"   Value="#22FFFFFF" />
            <Setter Property="Margin"       Value="10,0" />
        </Style>

        <!-- 라벨 텍스트 (좌측 키) -->
        <Style x:Key="KeyText" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="Foreground" Value="#FF9C9CAA" />
            <Setter Property="Width"      Value="70" />
            <Setter Property="Margin"     Value="10,1,4,1" />
        </Style>

        <!-- 값 텍스트 (우측) -->
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontSize"              Value="11" />
            <Setter Property="FontFamily"            Value="Consolas" />
            <Setter Property="Foreground"            Value="#FFDDDDE8" />
            <Setter Property="Margin"                Value="0,1,10,1" />
            <Setter Property="TextWrapping"          Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <!--
        반투명 다크 패널. DataContext = MisbMetadataDisplayModel.
        스크롤 가능하여 표적 목록이 길어도 넘치지 않음.
    -->
    <Border
        Background="#E60D0B14"
        BorderBrush="#33FFFFFF"
        BorderThickness="0,0,0,0"
        CornerRadius="0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- 헤더 타이틀바 -->
                <RowDefinition Height="*" />     <!-- 스크롤 컨텐츠 -->
            </Grid.RowDefinitions>

            <!-- ══ 타이틀바 ════════════════════════════════════════════ -->
            <Border
                Grid.Row="0"
                Background="#CC1A0F2E"
                BorderBrush="#44FFFFFF"
                BorderThickness="0,0,0,1"
                Padding="10,7">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Text="MISB 메타데이터"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#FFB89AEF"
                        VerticalAlignment="Center" />
                    <TextBlock
                        Text="{Binding PlaybackTimestamp}"
                        FontSize="10"
                        FontFamily="Consolas"
                        Foreground="#FF7C7C8F"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ══ 스크롤 컨텐츠 ══════════════════════════════════════ -->
            <ScrollViewer
                Grid.Row="1"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">

                <StackPanel>

                    <!-- ─── 타임스탬프 ─── -->
                    <TextBlock
                        Style="{StaticResource SectionHeader}"
                        Text="⏱ 타임스탬프" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="UTC" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding PrecisionTimestamp}" />
                    </StackPanel>

                    <Border Style="{StaticResource Divider}" Margin="10,6" />

                    <!-- ─── 플랫폼 식별 ─── -->
                    <TextBlock
                        Style="{StaticResource SectionHeader}"
                        Text="✈ 플랫폼" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="미션 ID" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding MissionId}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="꼬리번호" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding TailNumber}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="버전" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding VersionNumber}" />
                    </StackPanel>

                    <Border Style="{StaticResource Divider}" Margin="10,6" />

                    <!-- ─── 센서 위치 ─── -->
                    <TextBlock
                        Style="{StaticResource SectionHeader}"
                        Text="📍 센서 위치" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="위도" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding SensorLatitude}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="경도" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding SensorLongitude}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="고도(MSL)" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding SensorAltitude}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="고도(HAE)" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding SensorEllipsoidHeight}" />
                    </StackPanel>

                    <Border Style="{StaticResource Divider}" Margin="10,6" />

                    <!-- ─── 플랫폼 자세 ─── -->
                    <TextBlock
                        Style="{StaticResource SectionHeader}"
                        Text="🧭 플랫폼 자세" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="헤딩" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding Heading}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="피치" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding Pitch}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="롤" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding Roll}" />
                    </StackPanel>

                    <Border Style="{StaticResource Divider}" Margin="10,6" />

                    <!-- ─── 센서 FOV ─── -->
                    <TextBlock
                        Style="{StaticResource SectionHeader}"
                        Text="🔭 센서 FOV / 방위" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="수평 FOV" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding HorizontalFov}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="수직 FOV" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding VerticalFov}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="방위각" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding RelativeAzimuth}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="앙각" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding RelativeElevation}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="롤각" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding RelativeRoll}" />
                    </StackPanel>

                    <Border Style="{StaticResource Divider}" Margin="10,6" />

                    <!-- ─── 프레임 중심 ─── -->
                    <TextBlock
                        Style="{StaticResource SectionHeader}"
                        Text="🎯 프레임 중심" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="위도" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding FrameCenterLat}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="경도" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding FrameCenterLon}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource KeyText}" Text="고도" />
                        <TextBlock Style="{StaticResource ValueText}"
                                   Text="{Binding FrameCenterAlt}" />
                    </StackPanel>

                    <!-- ─── 프레임 모서리 ─── -->
                    <Border
                        Style="{StaticResource Divider}"
                        Margin="10,6"
                        Visibility="{Binding HasCornerPoints, Converter={StaticResource BoolToVis}}" />

                    <TextBlock
                        Style="{StaticResource SectionHeader}"
                        Text="⬜ 프레임 모서리"
                        Visibility="{Binding HasCornerPoints, Converter={StaticResource BoolToVis}}" />
                    <StackPanel
                        Visibility="{Binding HasCornerPoints, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource KeyText}" Text="좌상 (TL)" />
                            <TextBlock Style="{StaticResource ValueText}"
                                       Text="{Binding CornerTL}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource KeyText}" Text="우상 (TR)" />
                            <TextBlock Style="{StaticResource ValueText}"
                                       Text="{Binding CornerTR}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource KeyText}" Text="우하 (BR)" />
                            <TextBlock Style="{StaticResource ValueText}"
                                       Text="{Binding CornerBR}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource KeyText}" Text="좌하 (BL)" />
                            <TextBlock Style="{StaticResource ValueText}"
                                       Text="{Binding CornerBL}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- ─── VMTI ─── -->
                    <Border
                        Style="{StaticResource Divider}"
                        Margin="10,6"
                        Visibility="{Binding HasVmti, Converter={StaticResource BoolToVis}}" />

                    <TextBlock
                        Style="{StaticResource SectionHeader}"
                        Visibility="{Binding HasVmti, Converter={StaticResource BoolToVis}}">
                        <Run Text="👁 VMTI (" />
                        <Run Text="{Binding VmtiTargetCountText}" />
                        <Run Text=")" />
                    </TextBlock>

                    <StackPanel
                        Visibility="{Binding HasVmti, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource KeyText}" Text="시스템" />
                            <TextBlock Style="{StaticResource ValueText}"
                                       Text="{Binding VmtiSystem}" />
                        </StackPanel>
                        <TextBlock
                            Style="{StaticResource ValueText}"
                            Text="{Binding VmtiTargetsText}"
                            Margin="10,4,10,4"
                            LineHeight="18"
                            Foreground="#FFCFCFE0" />
                    </StackPanel>

                    <!-- 하단 여백 -->
                    <Border Height="16" />

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
