<Page
    x:Class="fflux.UI.Modules.Player.PlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:conv="clr-namespace:fflux.UI.Shared.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:fflux.UI.Modules.Player"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=local:PlayerViewModel, IsDesignTimeCreatable=False}"
    d:DesignHeight="600"
    d:DesignWidth="960"
    Title="Player">

    <Page.Resources>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <BooleanToVisibilityConverter          x:Key="BoolToVis" />
    </Page.Resources>

    <Grid
        x:Name="RootGrid"
        Focusable="True"
        KeyDown="OnKeyDown">

        <Grid.RowDefinitions>
            <!-- 비디오 영역 -->
            <RowDefinition Height="*" />
            <!-- 컨트롤 바 -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ══ 비디오 영역 ══════════════════════════════════════════════ -->
        <Border
            Grid.Row="0"
            Background="Black"
            AllowDrop="True"
            Drop="OnVideoDrop"
            DragOver="OnVideoDragOver">

            <Image
                Source="{Binding VideoBitmap}"
                Stretch="Uniform"
                RenderOptions.BitmapScalingMode="Linear" />

        </Border>

        <!-- 파일 드롭 힌트 (파일 미열기 상태) -->
        <Grid
            Grid.Row="0"
            IsHitTestVisible="False"
            Visibility="{Binding IsFileOpen, Converter={StaticResource InvBoolToVis}}">

            <StackPanel
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

                <ui:SymbolIcon
                    Symbol="FolderOpen28"
                    FontSize="56"
                    Foreground="{DynamicResource FFluxSecondaryBrush}"
                    HorizontalAlignment="Center" />

                <TextBlock
                    Text="미디어 파일을 드롭하거나 열기 버튼을 누르세요"
                    FontSize="14"
                    Margin="0,16,0,0"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center" />

                <TextBlock
                    Text="MP4 · MKV · AVI · MOV · WMV · WebM · TS"
                    FontSize="12"
                    Margin="0,6,0,0"
                    Foreground="{DynamicResource TextFillColorDisabledBrush}"
                    HorizontalAlignment="Center" />

            </StackPanel>
        </Grid>

        <!-- ══ 컨트롤 바 ════════════════════════════════════════════════ -->
        <Border
            Grid.Row="1"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource FFluxBorderBrush}"
            Background="{DynamicResource FFluxSurfaceVariantBrush}"
            Padding="16,10,16,12">

            <Grid>
                <Grid.RowDefinitions>
                    <!-- 시크 슬라이더 -->
                    <RowDefinition Height="Auto" />
                    <!-- 버튼 + 상태 + 볼륨/속도/타임코드 -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ── 시크 슬라이더 ─────────────────────────────── -->
                <Slider
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    Minimum="0"
                    Maximum="{Binding DurationSeconds}"
                    Value="{Binding PositionSeconds, Mode=TwoWay}"
                    IsEnabled="{Binding IsFileOpen}"
                    TickFrequency="1"
                    SmallChange="1"
                    LargeChange="10" />

                <!-- ── 버튼 행 ───────────────────────────────────── -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 트랜스포트 버튼 -->
                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                        <ui:Button
                            Margin="0,0,6,0"
                            Command="{Binding OpenFileCommand}"
                            Appearance="Secondary"
                            ToolTip="파일 열기 (지원: MP4, MKV, AVI, MOV, WebM …)">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14" Margin="0,0,6,0" />
                                <TextBlock Text="열기" />
                            </StackPanel>
                        </ui:Button>

                        <ui:Button
                            Margin="0,0,4,0"
                            Width="36" Height="36"
                            Command="{Binding PlayCommand}"
                            Appearance="Primary"
                            ToolTip="재생 (Space)">
                            <ui:SymbolIcon Symbol="Play24" FontSize="14" />
                        </ui:Button>

                        <ui:Button
                            Margin="0,0,4,0"
                            Width="36" Height="36"
                            Command="{Binding PauseCommand}"
                            Appearance="Secondary"
                            ToolTip="일시 정지 (Space)">
                            <ui:SymbolIcon Symbol="Pause24" FontSize="14" />
                        </ui:Button>

                        <ui:Button
                            Width="36" Height="36"
                            Command="{Binding StopCommand}"
                            Appearance="Secondary"
                            ToolTip="정지">
                            <ui:SymbolIcon Symbol="Stop24" FontSize="14" />
                        </ui:Button>

                    </StackPanel>

                    <!-- 상태 텍스트 (중앙) -->
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding StatusText}"
                        FontSize="12"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <!-- 우측: 볼륨 + 속도 + 타임코드 -->
                    <StackPanel
                        Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                        <!-- 음소거 토글 버튼 -->
                        <ui:Button
                            Margin="0,0,2,0"
                            Width="32" Height="32"
                            Command="{Binding ToggleMuteCommand}"
                            Appearance="Transparent"
                            ToolTip="음소거 (M)">
                            <ui:SymbolIcon
                                FontSize="14"
                                Symbol="{Binding VolumeSymbol}" />
                        </ui:Button>

                        <!-- 볼륨 슬라이더 -->
                        <Slider
                            Width="80"
                            Margin="0,0,12,0"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding VolumeLevel, Mode=TwoWay}"
                            VerticalAlignment="Center"
                            ToolTip="{Binding VolumeLevel, StringFormat='볼륨: {0:F0}'}" />

                        <!-- 재생 속도 -->
                        <TextBlock
                            Text="속도"
                            FontSize="11"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                        <ComboBox
                            Width="68"
                            Margin="0,0,12,0"
                            SelectedIndex="{Binding SelectedSpeedIndex, Mode=TwoWay}"
                            VerticalAlignment="Center"
                            FontSize="12"
                            ToolTip="재생 속도">
                            <ComboBoxItem>0.25×</ComboBoxItem>
                            <ComboBoxItem>0.5×</ComboBoxItem>
                            <ComboBoxItem>0.75×</ComboBoxItem>
                            <ComboBoxItem>1×</ComboBoxItem>
                            <ComboBoxItem>1.25×</ComboBoxItem>
                            <ComboBoxItem>1.5×</ComboBoxItem>
                            <ComboBoxItem>2×</ComboBoxItem>
                        </ComboBox>

                        <!-- 타임코드 -->
                        <TextBlock
                            Text="{Binding TimecodeText}"
                            FontSize="12"
                            VerticalAlignment="Center"
                            FontFamily="Consolas, Courier New"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                    </StackPanel>

                </Grid>
            </Grid>
        </Border>

    </Grid>
</Page>
