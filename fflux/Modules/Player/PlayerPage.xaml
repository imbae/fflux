<Page
    x:Class="fflux.UI.Modules.Player.PlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:conv="clr-namespace:fflux.UI.Shared.Converters"
    xmlns:ctrl="clr-namespace:fflux.UI.Shared.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:fflux.UI.Modules.Player"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=local:PlayerViewModel, IsDesignTimeCreatable=False}"
    d:DesignHeight="600"
    d:DesignWidth="960"
    Title="Player"
    ScrollViewer.VerticalScrollBarVisibility="Disabled"
    ScrollViewer.HorizontalScrollBarVisibility="Disabled">

    <Page.Resources>
        <conv:InverseBoolToVisibilityConverter
            x:Key="InvBoolToVis" />
        <BooleanToVisibilityConverter
            x:Key="BoolToVis" />

        <!-- 프레임 스텝 버튼: hold-to-repeat을 위해 RepeatButton 사용 -->
        <Style
            x:Key="FrameStepStyle"
            TargetType="RepeatButton">
            <Setter
                Property="Background"
                Value="Transparent" />
            <Setter
                Property="BorderThickness"
                Value="0" />
            <Setter
                Property="Padding"
                Value="0" />
            <Setter
                Property="Width"
                Value="32" />
            <Setter
                Property="Height"
                Value="32" />
            <Setter
                Property="Cursor"
                Value="Hand" />
            <Setter
                Property="Foreground"
                Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter
                Property="Delay"
                Value="400" />
            <Setter
                Property="Interval"
                Value="80" />
            <Setter
                Property="Template">
                <Setter.Value>
                    <ControlTemplate
                        TargetType="RepeatButton">
                        <Border
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger
                                Property="IsMouseOver"
                                Value="True">
                                <Setter
                                    Property="Background"
                                    Value="#22FFFFFF" />
                            </Trigger>
                            <Trigger
                                Property="IsPressed"
                                Value="True">
                                <Setter
                                    Property="Background"
                                    Value="#44FFFFFF" />
                            </Trigger>
                            <Trigger
                                Property="IsEnabled"
                                Value="False">
                                <Setter
                                    Property="Opacity"
                                    Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <!--
        RootGrid — 단일 셀: 비디오, 드롭 힌트, 컨트롤 바가 모두 같은 셀에 오버레이됩니다.
        MouseMove / MouseLeave 이벤트로 컨트롤 바 자동 숨김을 제어합니다.
    -->
    <Grid
        x:Name="RootGrid"
        Background="Black"
        Focusable="True"
        KeyDown="OnKeyDown"
        MouseMove="OnMouseMove"
        MouseLeave="OnMouseLeave"
        VerticalAlignment="Stretch"
        HorizontalAlignment="Stretch"
        ClipToBounds="True">

        <!-- ══ 비디오 영역 ══════════════════════════════════════════════ -->
        <Border
            AllowDrop="True"
            Drop="OnVideoDrop"
            DragOver="OnVideoDragOver">

            <Image
                Source="{Binding VideoBitmap}"
                Stretch="Uniform"
                RenderOptions.BitmapScalingMode="Linear" />

        </Border>

        <!-- ══ 드롭 힌트 (파일 미열기 상태) ══════════════════════════════ -->
        <Grid
            IsHitTestVisible="False"
            Visibility="{Binding IsFileOpen, Converter={StaticResource InvBoolToVis}}">

            <StackPanel
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

                <ui:SymbolIcon
                    Symbol="FolderOpen28"
                    FontSize="56"
                    Foreground="{DynamicResource FFluxSecondaryBrush}"
                    HorizontalAlignment="Center" />

                <TextBlock
                    Text="미디어 파일을 드롭하거나 열기 버튼을 누르세요"
                    FontSize="14"
                    Margin="0,16,0,0"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center" />

                <TextBlock
                    Text="MP4 · MKV · AVI · MOV · WMV · WebM · TS"
                    FontSize="12"
                    Margin="0,6,0,0"
                    Foreground="{DynamicResource TextFillColorDisabledBrush}"
                    HorizontalAlignment="Center" />

                <TextBlock
                    Text="또는 스트리밍 버튼으로 RTSP · RTP · UDP 주소 입력"
                    FontSize="12"
                    Margin="0,4,0,0"
                    Foreground="{DynamicResource TextFillColorDisabledBrush}"
                    HorizontalAlignment="Center" />

            </StackPanel>
        </Grid>

        <!-- ══ LIVE 배지 (라이브 스트림 재생 중) ══════════════════════════ -->
        <Border
            VerticalAlignment="Top"
            HorizontalAlignment="Left"
            Margin="12,12,0,0"
            Background="#CCDD2222"
            CornerRadius="4"
            Padding="7,3"
            Visibility="{Binding IsLiveStream, Converter={StaticResource BoolToVis}}">
            <TextBlock
                Text="● LIVE"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="White"
                VerticalAlignment="Center" />
        </Border>

        <!-- ══ 자막 오버레이 ═══════════════════════════════════════════
             컨트롤 바 위에 표시. IsSubtitleVisible=false 이면 Collapsed.
             텍스트가 빈 경우 내부 Border가 자동으로 숨겨집니다.
        ════════════════════════════════════════════════════════════════ -->
        <ctrl:SubtitleOverlayControl
            SubtitleText="{Binding SubtitleText}"
            SubtitleFontSize="{Binding SubtitleFontSize}"
            SubtitleColor="{Binding SubtitleColor}"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Center"
            Margin="80,0,80,112"
            Visibility="{Binding IsSubtitleVisible, Converter={StaticResource BoolToVis}}" />

        <!-- ══ 오버레이 컨트롤 바 ═══════════════════════════════════════
             VerticalAlignment="Bottom" 으로 하단에 고정.
             코드-비하인드에서 Opacity 애니메이션으로 자동 숨김을 구현합니다.
        ════════════════════════════════════════════════════════════════ -->
        <Border
            x:Name="ControlBar"
            VerticalAlignment="Bottom"
            Padding="16,32,16,12">

            <!-- 투명 → 반투명 퍼플 그라디언트 배경 -->
            <Border.Background>
                <LinearGradientBrush
                    StartPoint="0,0"
                    EndPoint="0,1">
                    <GradientStop
                        Color="Transparent"
                        Offset="0.0" />
                    <GradientStop
                        Color="#BB1A1428"
                        Offset="0.45" />
                    <GradientStop
                        Color="#F51A1428"
                        Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- 시크 슬라이더 -->
                    <RowDefinition
                        Height="Auto" />
                    <!-- 버튼 행 -->
                    <RowDefinition
                        Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ── 시크 슬라이더 (라이브 스트림 중에는 비활성화) ────── -->
                <Slider
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    Minimum="0"
                    Maximum="{Binding DurationSeconds}"
                    Value="{Binding PositionSeconds, Mode=TwoWay}"
                    IsEnabled="{Binding CanSeek}"
                    TickFrequency="1"
                    SmallChange="1"
                    LargeChange="10" />

                <!-- ── 버튼 행 ───────────────────────────────────── -->
                <Grid
                    Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition
                            Width="Auto" />
                        <ColumnDefinition
                            Width="*" />
                        <ColumnDefinition
                            Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 좌측: 트랜스포트 버튼 -->
                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                        <!-- 파일 열기 -->
                        <ui:Button
                            Margin="0,0,2,0"
                            Command="{Binding OpenFileCommand}"
                            Appearance="Secondary"
                            ToolTip="미디어 파일 열기">
                            <StackPanel
                                Orientation="Horizontal">
                                <ui:SymbolIcon
                                    Symbol="FolderOpen24"
                                    FontSize="14"
                                    Margin="0,0,6,0" />
                                <TextBlock
                                    Text="열기" />
                            </StackPanel>
                        </ui:Button>

                        <!-- 스트리밍 URL 열기 -->
                        <ui:Button
                            Margin="0,0,6,0"
                            Command="{Binding OpenStreamCommand}"
                            Appearance="Secondary"
                            ToolTip="RTSP / RTP / UDP 스트리밍 주소 입력">
                            <StackPanel
                                Orientation="Horizontal">
                                <ui:SymbolIcon
                                    Symbol="Stream24"
                                    FontSize="14"
                                    Margin="0,0,6,0" />
                                <TextBlock
                                    Text="스트리밍" />
                            </StackPanel>
                        </ui:Button>

                        <!-- 자막 열기 -->
                        <ui:Button
                            Margin="0,0,2,0"
                            Command="{Binding LoadSubtitleCommand}"
                            Appearance="Secondary"
                            ToolTip="자막 파일 열기 (SRT / VTT)">
                            <StackPanel
                                Orientation="Horizontal">
                                <ui:SymbolIcon
                                    Symbol="Subtitles24"
                                    FontSize="14"
                                    Margin="0,0,6,0" />
                                <TextBlock
                                    Text="자막" />
                            </StackPanel>
                        </ui:Button>

                        <!-- 자막 표시 토글 -->
                        <ui:Button
                            Margin="0,0,6,0"
                            Width="32"
                            Height="32"
                            Command="{Binding ToggleSubtitleCommand}"
                            Appearance="Secondary"
                            ToolTip="자막 표시/숨김 (V)">
                            <ui:SymbolIcon
                                FontSize="14">
                                <ui:SymbolIcon.Style>
                                    <Style
                                        TargetType="ui:SymbolIcon">
                                        <Setter
                                            Property="Symbol"
                                            Value="Subtitles24" />
                                        <Style.Triggers>
                                            <DataTrigger
                                                Binding="{Binding IsSubtitleVisible}"
                                                Value="False">
                                                <Setter
                                                    Property="Symbol"
                                                    Value="Subtitles24" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                        </ui:Button>

                        <!-- 프레임 뒤로 (hold-to-repeat) -->
                        <RepeatButton
                            Margin="0,0,2,0"
                            Style="{StaticResource FrameStepStyle}"
                            Command="{Binding StepFrameBackwardCommand}"
                            ToolTip="이전 프레임 (Ctrl+←)">
                            <ui:SymbolIcon
                                Symbol="PreviousFrame24"
                                FontSize="14" />
                        </RepeatButton>

                        <!-- 재생 -->
                        <ui:Button
                            Margin="0,0,2,0"
                            Width="36"
                            Height="36"
                            Command="{Binding PlayCommand}"
                            Appearance="Primary"
                            ToolTip="재생 (Space)">
                            <ui:SymbolIcon
                                Symbol="Play24"
                                FontSize="14" />
                        </ui:Button>

                        <!-- 일시정지 -->
                        <ui:Button
                            Margin="0,0,2,0"
                            Width="36"
                            Height="36"
                            Command="{Binding PauseCommand}"
                            Appearance="Secondary"
                            ToolTip="일시 정지 (Space)">
                            <ui:SymbolIcon
                                Symbol="Pause24"
                                FontSize="14" />
                        </ui:Button>

                        <!-- 정지 -->
                        <ui:Button
                            Margin="0,0,2,0"
                            Width="36"
                            Height="36"
                            Command="{Binding StopCommand}"
                            Appearance="Secondary"
                            ToolTip="정지">
                            <ui:SymbolIcon
                                Symbol="Stop24"
                                FontSize="14" />
                        </ui:Button>

                        <!-- 프레임 앞으로 (hold-to-repeat) -->
                        <RepeatButton
                            Style="{StaticResource FrameStepStyle}"
                            Command="{Binding StepFrameForwardCommand}"
                            ToolTip="다음 프레임 (Ctrl+→)">
                            <ui:SymbolIcon
                                Symbol="NextFrame24"
                                FontSize="14" />
                        </RepeatButton>

                    </StackPanel>

                    <!-- 중앙: 상태 텍스트 -->
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding StatusText}"
                        FontSize="12"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <!-- 우측: 볼륨 + 속도 + 타임코드 + 풀스크린 -->
                    <StackPanel
                        Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                        <!-- 음소거 버튼 -->
                        <ui:Button
                            Margin="0,0,2,0"
                            Width="32"
                            Height="32"
                            Command="{Binding ToggleMuteCommand}"
                            Appearance="Transparent"
                            ToolTip="음소거 (M)">
                            <ui:SymbolIcon
                                FontSize="14"
                                Symbol="{Binding VolumeSymbol}" />
                        </ui:Button>

                        <!-- 볼륨 슬라이더 -->
                        <Slider
                            Width="80"
                            Margin="0,0,12,0"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding VolumeLevel, Mode=TwoWay}"
                            VerticalAlignment="Center"
                            ToolTip="{Binding VolumeLevel, StringFormat='볼륨: {0:F0}'}" />

                        <!-- 재생 속도 -->
                        <TextBlock
                            Text="속도"
                            FontSize="11"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                        <ComboBox
                            Width="68"
                            Margin="0,0,12,0"
                            SelectedIndex="{Binding SelectedSpeedIndex, Mode=TwoWay}"
                            VerticalAlignment="Center"
                            FontSize="12"
                            ToolTip="재생 속도">
                            <ComboBoxItem>0.25×</ComboBoxItem>
                            <ComboBoxItem>0.5×</ComboBoxItem>
                            <ComboBoxItem>0.75×</ComboBoxItem>
                            <ComboBoxItem>1×</ComboBoxItem>
                            <ComboBoxItem>1.25×</ComboBoxItem>
                            <ComboBoxItem>1.5×</ComboBoxItem>
                            <ComboBoxItem>2×</ComboBoxItem>
                        </ComboBox>

                        <!-- 타임코드 -->
                        <TextBlock
                            Margin="0,0,8,0"
                            Text="{Binding TimecodeText}"
                            FontSize="12"
                            VerticalAlignment="Center"
                            FontFamily="Consolas, Courier New"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <!-- 풀스크린 버튼 -->
                        <ui:Button
                            Width="32"
                            Height="32"
                            Command="{Binding ToggleFullscreenCommand}"
                            Appearance="Transparent"
                            ToolTip="전체 화면 (F)">
                            <ui:SymbolIcon
                                FontSize="14">
                                <ui:SymbolIcon.Style>
                                    <Style
                                        TargetType="ui:SymbolIcon">
                                        <Setter
                                            Property="Symbol"
                                            Value="FullScreenMaximize24" />
                                        <Style.Triggers>
                                            <DataTrigger
                                                Binding="{Binding IsFullscreen}"
                                                Value="True">
                                                <Setter
                                                    Property="Symbol"
                                                    Value="FullScreenMinimize24" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                        </ui:Button>

                    </StackPanel>

                </Grid>
            </Grid>
        </Border>

    </Grid>
</Page>
