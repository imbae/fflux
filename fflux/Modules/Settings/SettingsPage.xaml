<Page
    x:Class="fflux.UI.Modules.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:fflux.UI.Modules.Settings"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
    d:DesignHeight="800"
    d:DesignWidth="900"
    Title="Settings">

    <ScrollViewer
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            Margin="32,24,32,32"
            MaxWidth="760">

            <!-- ── 페이지 헤더 ──────────────────────────────── -->
            <TextBlock
                Text="설정"
                FontSize="28"
                FontWeight="SemiBold"
                Margin="0,0,0,24"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <!-- ══ Card: FFmpeg 설정 ═══════════════════════════ -->
            <ui:Card
                Margin="0,0,0,16"
                Padding="24,20">
                <StackPanel>

                    <!-- 섹션 제목 -->
                    <StackPanel
                        Orientation="Horizontal"
                        Margin="0,0,0,4">
                        <ui:SymbolIcon
                            Symbol="VideoClip24"
                            FontSize="18"
                            Foreground="{DynamicResource FFluxSecondaryBrush}"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Text="FFmpeg 설정"
                            FontSize="16"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock
                        Text="FFmpeg LGPL 바이너리가 있는 폴더 경로를 지정합니다. (ffmpeg.exe 포함 폴더)"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Margin="0,0,0,16" />

                    <!-- 경로 입력 + 찾아보기 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBox
                            Grid.Column="0"
                            PlaceholderText="예: C:\ffmpeg\bin"
                            Text="{Binding FFmpegBinaryPath, UpdateSourceTrigger=PropertyChanged}"
                            FontFamily="Consolas, Courier New"
                            Margin="0,0,8,0" />

                        <ui:Button
                            Grid.Column="1"
                            Content="찾아보기"
                            Icon="{ui:SymbolIcon FolderOpen24}"
                            Command="{Binding BrowseFFmpegPathCommand}" />
                    </Grid>

                    <!-- 유효성 경고 -->
                    <TextBlock
                        Text="{Binding FFmpegPathValidation}"
                        FontSize="12"
                        Foreground="{DynamicResource FFluxWarningBrush}"
                        Margin="0,6,0,0"
                        Visibility="{Binding FFmpegPathValidation,
                                     Converter={StaticResource StringToVisibilityConverter}}" />

                </StackPanel>
            </ui:Card>

            <!-- ══ Card: 외관 ══════════════════════════════════ -->
            <ui:Card
                Margin="0,0,0,16"
                Padding="24,20">
                <StackPanel>

                    <StackPanel
                        Orientation="Horizontal"
                        Margin="0,0,0,4">
                        <ui:SymbolIcon
                            Symbol="PaintBrush24"
                            FontSize="18"
                            Foreground="{DynamicResource FFluxSecondaryBrush}"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Text="외관"
                            FontSize="16"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock
                        Text="앱 테마를 선택합니다. 변경 시 즉시 적용됩니다."
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Margin="0,0,0,16" />

                    <!-- 테마 선택 RadioButton -->
                    <StackPanel Orientation="Horizontal">

                        <Border
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16,12"
                            Margin="0,0,12,0"
                            MinWidth="130">
                            <RadioButton
                                Content="🌐  시스템"
                                IsChecked="{Binding IsSystemTheme}"
                                GroupName="ThemeGroup"
                                FontSize="13" />
                        </Border>

                        <Border
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16,12"
                            Margin="0,0,12,0"
                            MinWidth="130">
                            <RadioButton
                                Content="☀️  라이트"
                                IsChecked="{Binding IsLightTheme}"
                                GroupName="ThemeGroup"
                                FontSize="13" />
                        </Border>

                        <Border
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="16,12"
                            MinWidth="130">
                            <RadioButton
                                Content="🌙  다크"
                                IsChecked="{Binding IsDarkTheme}"
                                GroupName="ThemeGroup"
                                FontSize="13" />
                        </Border>

                    </StackPanel>

                </StackPanel>
            </ui:Card>

            <!-- ══ Card: 출력 설정 ════════════════════════════ -->
            <ui:Card
                Margin="0,0,0,16"
                Padding="24,20">
                <StackPanel>

                    <StackPanel
                        Orientation="Horizontal"
                        Margin="0,0,0,4">
                        <ui:SymbolIcon
                            Symbol="Folder24"
                            FontSize="18"
                            Foreground="{DynamicResource FFluxSecondaryBrush}"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Text="출력 설정"
                            FontSize="16"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock
                        Text="인코딩 결과물이 저장될 기본 폴더입니다."
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Margin="0,0,0,16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBox
                            Grid.Column="0"
                            PlaceholderText="예: D:\Output"
                            Text="{Binding DefaultOutputFolder, UpdateSourceTrigger=PropertyChanged}"
                            FontFamily="Consolas, Courier New"
                            Margin="0,0,8,0" />

                        <ui:Button
                            Grid.Column="1"
                            Content="찾아보기"
                            Icon="{ui:SymbolIcon FolderOpen24}"
                            Command="{Binding BrowseOutputFolderCommand}" />
                    </Grid>

                    <TextBlock
                        Text="{Binding OutputFolderValidation}"
                        FontSize="12"
                        Foreground="{DynamicResource FFluxWarningBrush}"
                        Margin="0,6,0,0"
                        Visibility="{Binding OutputFolderValidation,
                                     Converter={StaticResource StringToVisibilityConverter}}" />

                </StackPanel>
            </ui:Card>

            <!-- ══ Card: 언어 (추후 지원 예정) ══════════════ -->
            <ui:Card
                Margin="0,0,0,24"
                Padding="24,20"
                Opacity="0.55"
                IsEnabled="False">
                <StackPanel>

                    <StackPanel
                        Orientation="Horizontal"
                        Margin="0,0,0,4">
                        <ui:SymbolIcon
                            Symbol="LocalLanguage24"
                            FontSize="18"
                            Foreground="{DynamicResource FFluxSecondaryBrush}"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Text="언어"
                            FontSize="16"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center" />
                        <Border
                            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="4"
                            Padding="6,2"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                            <TextBlock
                                Text="추후 지원 예정"
                                FontSize="11"
                                Foreground="{DynamicResource TextFillColorDisabledBrush}" />
                        </Border>
                    </StackPanel>

                    <TextBlock
                        Text="앱 인터페이스 언어를 선택합니다. (현재 한국어만 지원)"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Margin="0,0,0,16" />

                    <ComboBox
                        Width="200"
                        HorizontalAlignment="Left"
                        SelectedIndex="0">
                        <ComboBoxItem Content="한국어 (Korean)" />
                        <ComboBoxItem Content="English" />
                    </ComboBox>

                </StackPanel>
            </ui:Card>

            <!-- ══ 버튼 영역 ════════════════════════════════ -->
            <StackPanel Orientation="Horizontal">

                <ui:Button
                    Content="설정 저장"
                    Appearance="Primary"
                    Icon="{ui:SymbolIcon Save24}"
                    Command="{Binding SaveCommand}"
                    MinWidth="120"
                    Margin="0,0,12,0" />

                <ui:Button
                    Content="기본값으로 초기화"
                    Appearance="Secondary"
                    Icon="{ui:SymbolIcon ArrowReset24}"
                    Command="{Binding ResetToDefaultsCommand}"
                    MinWidth="140" />

                <!-- 미저장 변경 알림 -->
                <TextBlock
                    Text="● 저장되지 않은 변경사항이 있습니다."
                    FontSize="12"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"
                    Foreground="{DynamicResource FFluxWarningBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger
                                    Binding="{Binding HasUnsavedChanges}"
                                    Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
