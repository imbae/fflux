<Page
    x:Class="fflux.UI.Modules.VideoAnalyzer.VideoAnalyzerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:conv="clr-namespace:fflux.UI.Shared.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:fflux.UI.Modules.VideoAnalyzer"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=local:VideoAnalyzerViewModel, IsDesignTimeCreatable=False}"
    d:DesignHeight="720"
    d:DesignWidth="960"
    AllowDrop="True"
    Title="Stream Analyzer">

    <Page.Resources>
        <BooleanToVisibilityConverter
            x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter
            x:Key="InvBoolToVis" />

        <!-- 레이블 (회색 보조 텍스트) -->
        <Style
            x:Key="InfoLabel"
            TargetType="TextBlock">
            <Setter
                Property="Foreground"
                Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter
                Property="FontSize"
                Value="12" />
            <Setter
                Property="VerticalAlignment"
                Value="Center" />
            <Setter
                Property="Margin"
                Value="0,0,12,0" />
        </Style>

        <!-- 값 (밝은 주 텍스트) -->
        <Style
            x:Key="InfoValue"
            TargetType="TextBlock">
            <Setter
                Property="Foreground"
                Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter
                Property="FontSize"
                Value="13" />
            <Setter
                Property="TextWrapping"
                Value="Wrap" />
            <Setter
                Property="VerticalAlignment"
                Value="Center" />
        </Style>

        <!-- 섹션 제목 -->
        <Style
            x:Key="SectionTitle"
            TargetType="TextBlock">
            <Setter
                Property="FontSize"
                Value="13" />
            <Setter
                Property="FontWeight"
                Value="SemiBold" />
            <Setter
                Property="Foreground"
                Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter
                Property="Margin"
                Value="0,16,0,8" />
        </Style>

        <!-- 스트림 카드 -->
        <Style
            x:Key="StreamCard"
            TargetType="Border">
            <Setter
                Property="Background"
                Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter
                Property="BorderBrush"
                Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter
                Property="BorderThickness"
                Value="1" />
            <Setter
                Property="CornerRadius"
                Value="6" />
            <Setter
                Property="Padding"
                Value="14,12" />
            <Setter
                Property="Margin"
                Value="0,0,0,8" />
        </Style>

        <!-- 2-column 레이블/값 행 간격 -->
        <Style
            x:Key="InfoRow"
            TargetType="Grid">
            <Setter
                Property="Margin"
                Value="0,0,0,8" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition
                Height="Auto" />
            <!-- 파일 입력 바 -->
            <RowDefinition
                Height="Auto" />
            <!-- 상태 텍스트 + 진행 바 -->
            <RowDefinition
                Height="*" />
            <!-- 결과 / 빈 상태 -->
        </Grid.RowDefinitions>

        <!-- ══ ① 파일 입력 바 ══════════════════════════════════════════ -->
        <Border
            Grid.Row="0"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox
                    Grid.Column="0"
                    PlaceholderText="미디어 파일 경로 (드래그 또는 열기)"
                    Text="{Binding FilePath, Mode=OneWay}"
                    IsReadOnly="True"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0" />

                <ui:Button
                    Grid.Column="1"
                    Content="열기"
                    Command="{Binding BrowseFileCommand}"
                    Margin="0,0,8,0" />

                <ui:Button
                    Grid.Column="2"
                    Content="분석"
                    Appearance="Primary"
                    Command="{Binding AnalyzeCommand}"
                    Margin="0,0,8,0" />

                <ui:Button
                    Grid.Column="3"
                    Content="보고서 복사"
                    Icon="{ui:SymbolIcon Symbol=Copy24}"
                    Command="{Binding CopyReportCommand}"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>

        <!-- ══ ② 상태 텍스트 + 분석 중 진행 바 ══════════════════════════ -->
        <StackPanel
            Grid.Row="1">
            <TextBlock
                Text="{Binding StatusText}"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                FontSize="12"
                Margin="20,8,20,4" />

            <ProgressBar
                IsIndeterminate="True"
                Height="2"
                Margin="0"
                Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <!-- ══ ③-A 결과 (HasResult=True) ═══════════════════════════════ -->
        <ScrollViewer
            Grid.Row="2"
            Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                Margin="20,4,20,24">

                <!-- ── 컨테이너 정보 ─────────────────────────────────── -->
                <TextBlock
                    Text="컨테이너"
                    Style="{StaticResource SectionTitle}"
                    Margin="0,8,0,8" />

                <Border
                    Style="{StaticResource StreamCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="110" />
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="110" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition
                                Height="Auto" />
                            <RowDefinition
                                Height="Auto" />
                            <RowDefinition
                                Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="파일명"
                            Style="{StaticResource InfoLabel}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Grid.ColumnSpan="3"
                            Text="{Binding MediaInfo.FileName}"
                            Style="{StaticResource InfoValue}"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Text="포맷"
                            Style="{StaticResource InfoLabel}"
                            Margin="0,10,12,0" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Text="{Binding MediaInfo.FormatLongName}"
                            Style="{StaticResource InfoValue}"
                            Margin="0,10,0,0" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            Text="파일 크기"
                            Style="{StaticResource InfoLabel}"
                            Margin="0,10,12,0" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="3"
                            Text="{Binding MediaInfo.FileSizeText}"
                            Style="{StaticResource InfoValue}"
                            Margin="0,10,0,0" />

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Text="재생 시간"
                            Style="{StaticResource InfoLabel}"
                            Margin="0,8,12,0" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Text="{Binding MediaInfo.DurationText}"
                            Style="{StaticResource InfoValue}"
                            Margin="0,8,0,0" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="2"
                            Text="비트레이트"
                            Style="{StaticResource InfoLabel}"
                            Margin="0,8,12,0" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="3"
                            Text="{Binding MediaInfo.BitRateText, TargetNullValue='N/A'}"
                            Style="{StaticResource InfoValue}"
                            Margin="0,8,0,0" />
                    </Grid>
                </Border>

                <!-- ── 비디오 스트림 ──────────────────────────────────── -->
                <TextBlock
                    Text="비디오 스트림"
                    Style="{StaticResource SectionTitle}" />

                <ItemsControl
                    ItemsSource="{Binding MediaInfo.VideoStreams}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Style="{StaticResource StreamCard}">
                                <StackPanel>
                                    <!-- 헤더 -->
                                    <StackPanel
                                        Orientation="Horizontal"
                                        Margin="0,0,0,10">
                                        <ui:SymbolIcon
                                            Symbol="Video24"
                                            FontSize="16"
                                            Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            VerticalAlignment="Center">
                                            <Run
                                                Text="Video #" />
                                            <Run
                                                Text="{Binding StreamIndex, Mode=OneWay}" />
                                            <Run
                                                Text=" — " />
                                            <Run
                                                Text="{Binding CodecName, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- 프로퍼티 그리드 -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition
                                                Width="110" />
                                            <ColumnDefinition
                                                Width="*" />
                                            <ColumnDefinition
                                                Width="110" />
                                            <ColumnDefinition
                                                Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition
                                                Height="Auto" />
                                            <RowDefinition
                                                Height="Auto" />
                                            <RowDefinition
                                                Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Text="코덱"
                                            Style="{StaticResource InfoLabel}" />
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Text="{Binding CodecLongName}"
                                            Style="{StaticResource InfoValue}" />
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="2"
                                            Text="프로파일"
                                            Style="{StaticResource InfoLabel}" />
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="3"
                                            Text="{Binding Profile, TargetNullValue='N/A'}"
                                            Style="{StaticResource InfoValue}" />

                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Text="해상도"
                                            Style="{StaticResource InfoLabel}"
                                            Margin="0,8,12,0" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Text="{Binding ResolutionText}"
                                            Style="{StaticResource InfoValue}"
                                            Margin="0,8,0,0" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="2"
                                            Text="프레임레이트"
                                            Style="{StaticResource InfoLabel}"
                                            Margin="0,8,12,0" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="3"
                                            Text="{Binding FrameRateText}"
                                            Style="{StaticResource InfoValue}"
                                            Margin="0,8,0,0" />

                                        <TextBlock
                                            Grid.Row="2"
                                            Grid.Column="0"
                                            Text="픽셀 포맷"
                                            Style="{StaticResource InfoLabel}"
                                            Margin="0,8,12,0" />
                                        <TextBlock
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            Text="{Binding PixelFormat}"
                                            Style="{StaticResource InfoValue}"
                                            Margin="0,8,0,0" />
                                        <TextBlock
                                            Grid.Row="2"
                                            Grid.Column="2"
                                            Text="비트레이트"
                                            Style="{StaticResource InfoLabel}"
                                            Margin="0,8,12,0" />
                                        <TextBlock
                                            Grid.Row="2"
                                            Grid.Column="3"
                                            Style="{StaticResource InfoValue}"
                                            Margin="0,8,0,0">
                                            <TextBlock.Text>
                                                <Binding
                                                    Path="BitRateMbps"
                                                    StringFormat="{}{0:F2} Mbps"
                                                    TargetNullValue="N/A" />
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 비디오 스트림 없음 -->
                <TextBlock
                    Text="비디오 스트림 없음"
                    Foreground="{DynamicResource TextFillColorDisabledBrush}"
                    FontSize="13"
                    Margin="0,0,0,8"
                    Visibility="{Binding HasVideoStreams, Converter={StaticResource InvBoolToVis}}" />

                <!-- ── 오디오 스트림 ──────────────────────────────────── -->
                <TextBlock
                    Text="오디오 스트림"
                    Style="{StaticResource SectionTitle}" />

                <ItemsControl
                    ItemsSource="{Binding MediaInfo.AudioStreams}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Style="{StaticResource StreamCard}">
                                <StackPanel>
                                    <!-- 헤더 -->
                                    <StackPanel
                                        Orientation="Horizontal"
                                        Margin="0,0,0,10">
                                        <ui:SymbolIcon
                                            Symbol="Speaker224"
                                            FontSize="16"
                                            Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            VerticalAlignment="Center">
                                            <Run
                                                Text="Audio #" />
                                            <Run
                                                Text="{Binding StreamIndex, Mode=OneWay}" />
                                            <Run
                                                Text=" — " />
                                            <Run
                                                Text="{Binding CodecName, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- 프로퍼티 그리드 -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition
                                                Width="110" />
                                            <ColumnDefinition
                                                Width="*" />
                                            <ColumnDefinition
                                                Width="110" />
                                            <ColumnDefinition
                                                Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition
                                                Height="Auto" />
                                            <RowDefinition
                                                Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Text="코덱"
                                            Style="{StaticResource InfoLabel}" />
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Text="{Binding CodecLongName}"
                                            Style="{StaticResource InfoValue}" />
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="2"
                                            Text="언어"
                                            Style="{StaticResource InfoLabel}" />
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="3"
                                            Text="{Binding Language, TargetNullValue='N/A'}"
                                            Style="{StaticResource InfoValue}" />

                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Text="샘플레이트"
                                            Style="{StaticResource InfoLabel}"
                                            Margin="0,8,12,0" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Text="{Binding SampleRateText}"
                                            Style="{StaticResource InfoValue}"
                                            Margin="0,8,0,0" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="2"
                                            Text="채널"
                                            Style="{StaticResource InfoLabel}"
                                            Margin="0,8,12,0" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="3"
                                            Text="{Binding ChannelLayout}"
                                            Style="{StaticResource InfoValue}"
                                            Margin="0,8,0,0" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 오디오 스트림 없음 -->
                <TextBlock
                    Text="오디오 스트림 없음"
                    Foreground="{DynamicResource TextFillColorDisabledBrush}"
                    FontSize="13"
                    Margin="0,0,0,8"
                    Visibility="{Binding HasAudioStreams, Converter={StaticResource InvBoolToVis}}" />

                <!-- ── 자막 스트림 ────────────────────────────────────── -->
                <TextBlock
                    Text="자막 스트림"
                    Style="{StaticResource SectionTitle}"
                    Visibility="{Binding HasSubtitleStreams, Converter={StaticResource BoolToVis}}" />

                <ItemsControl
                    ItemsSource="{Binding MediaInfo.SubtitleStreams}"
                    Visibility="{Binding HasSubtitleStreams, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Style="{StaticResource StreamCard}">
                                <StackPanel
                                    Orientation="Horizontal">
                                    <ui:SymbolIcon
                                        Symbol="SubtitlesFilled"
                                        FontSize="16"
                                        Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        VerticalAlignment="Center">
                                        <Run
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            Text="{Binding DisplayLabel, Mode=OneWay}" />
                                        <Run
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text=" — " />
                                        <Run
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding CodecName, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- ══ ③-B 빈 상태 (HasResult=False) ══════════════════════════ -->
        <StackPanel
            Grid.Row="2"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Visibility="{Binding HasResult, Converter={StaticResource InvBoolToVis}}">

            <ui:SymbolIcon
                Symbol="DocumentSearch24"
                FontSize="64"
                Foreground="{DynamicResource TextFillColorDisabledBrush}"
                HorizontalAlignment="Center" />

            <TextBlock
                Text="미디어 파일을 드래그하거나 열기 버튼을 눌러 스트림 정보를 분석하세요."
                FontSize="13"
                Margin="0,14,0,0"
                Foreground="{DynamicResource TextFillColorDisabledBrush}"
                HorizontalAlignment="Center" />
        </StackPanel>

    </Grid>
</Page>
