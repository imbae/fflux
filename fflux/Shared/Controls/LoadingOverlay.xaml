<UserControl
    x:Class="fflux.UI.Shared.Controls.LoadingOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="400"
    d:DesignHeight="300"
    Focusable="False">

    <!-- IsActive=False 이면 Collapsed -->
    <UserControl.Style>
        <Style
            TargetType="UserControl">
            <Style.Triggers>
                <DataTrigger
                    Binding="{Binding IsActive, RelativeSource={RelativeSource Self}}"
                    Value="False">
                    <Setter
                        Property="Visibility"
                        Value="Collapsed" />
                </DataTrigger>
                <DataTrigger
                    Binding="{Binding IsActive, RelativeSource={RelativeSource Self}}"
                    Value="True">
                    <Setter
                        Property="Visibility"
                        Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <!-- 반투명 배경 + 컨텐츠 -->
    <Grid>

        <!-- 반투명 배경 -->
        <Rectangle
            Fill="#CC0D0D1A" />

        <!-- 중앙 카드 -->
        <ui:Card
            Width="320"
            Padding="32,28"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">

            <StackPanel>

                <!-- 진행률 표시 -->
                <ProgressBar
                    x:Name="ProgressIndicator"
                    Height="4"
                    Margin="0,0,0,20"
                    IsIndeterminate="{Binding IsIndeterminate, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Value="{Binding Progress, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Minimum="0"
                    Maximum="100" />

                <!-- 메시지 -->
                <TextBlock
                    Text="{Binding Message, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    FontSize="14"
                    FontWeight="Medium"
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Center" />

                <!-- 진행률 % -->
                <TextBlock
                    x:Name="ProgressText"
                    FontSize="12"
                    TextAlignment="Center"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    Margin="0,6,0,0">
                    <TextBlock.Style>
                        <Style
                            TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger
                                    Binding="{Binding IsIndeterminate, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Value="True">
                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run
                        Text="{Binding Progress, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat={}{0:F0}}" />
                    <Run
                        Text="%" />
                </TextBlock>

                <!-- 취소 버튼 -->
                <ui:Button
                    Content="취소"
                    Appearance="Secondary"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0"
                    Command="{Binding CancelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ui:Button.Style>
                        <Style
                            TargetType="ui:Button"
                            BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Style.Triggers>
                                <DataTrigger
                                    Binding="{Binding CanCancel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Value="False">
                                    <Setter
                                        Property="Visibility"
                                        Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>

            </StackPanel>
        </ui:Card>
    </Grid>
</UserControl>
